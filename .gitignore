# ─────────────────────────────────────────────────────────────────────────────
# .gitignore for research-agent
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets & credentials (NEVER commit these) ────────────────────────────────
.env
.env.*
!.env.example          # .env.example IS committed (no real values inside)
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
*.ppk
secrets/
credentials/
*_credentials.json
*_service_account.json
token.json
auth.json

# ── Runtime data (generated, not source) ─────────────────────────────────────
reports/
cache/
sessions.db
sessions.db-shm
sessions.db-wal
*.db
*.sqlite
*.sqlite3

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
pip-wheel-metadata/
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
.env/

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/
junit.xml

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Linting ───────────────────────────────────────────────────────────────────
.ruff_cache/

# ── IDEs & editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── OS metadata ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
*.log.*
logs/

# ── Build / distribution ──────────────────────────────────────────────────────
*.whl
*.tar.gz
*.zip

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Temporary files ───────────────────────────────────────────────────────────
tmp/
temp/
.tmp/
*.tmp
*.bak
*.orig
